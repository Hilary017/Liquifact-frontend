# LiquiFact Frontend
# Public client-facing values; do not store secrets here.
#
# All NEXT_PUBLIC_* values are validated at build time by lib/config/env.js.
# A malformed URL or a disallowed scheme fails the build early — see README.

# Backend API base URL.
# Must be a well-formed http:// or https:// origin. Non-http(s) schemes
# (javascript:, data:, file:, ftp:, …) are rejected.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Base URL for SEO sitemap and robots.
# Must be a well-formed http:// or https:// origin.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stellar network for Freighter wallet integration (when integrating wallet).
# Optional; when set it must be exactly "testnet" or "public" (defaults to testnet).
NEXT_PUBLIC_STELLAR_NETWORK=testnet
